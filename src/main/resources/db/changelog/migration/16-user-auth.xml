<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
                   objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <property name="string.type" value="varchar(255)" dbms="!postgresql"/>
    <property name="string.type" value="text" dbms="postgresql"/>

    <changeSet id="1716400000000-1" author="appUser">
        <createSequence sequenceName="users_seq" schemaName="portfolio" incrementBy="50" startValue="1"/>

        <createTable tableName="users" schemaName="portfolio">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>
            <column name="username" type="${string.type}">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="${string.type}">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="${string.type}">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="account_locked" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="failed_login_attempts" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="lock_expires_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="version" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createSequence sequenceName="refresh_tokens_seq" schemaName="portfolio" incrementBy="50" startValue="1"/>

        <createTable tableName="refresh_tokens" schemaName="portfolio">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="${string.type}">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_refresh_token_user" references="portfolio.users(id)"/>
            </column>
            <column name="expires_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="revoked" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="version" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
