<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1716462000000-1" author="appUser">
        <createSequence incrementBy="50" schemaName="portfolio" sequenceName="user_folio_value_seq" startValue="1"/>
    </changeSet>

    <changeSet id="1716462000000-2" author="appUser">
        <createTable schemaName="portfolio" tableName="user_folio_value">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="invested" type="DECIMAL(30, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="DECIMAL(30, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="user_folio_details_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="${timestamp.type}" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="${timestamp.type}" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="smallint" defaultValueNumeric="0"/>
        </createTable>
    </changeSet>

    <changeSet id="1716462000000-3" author="appUser">
        <addForeignKeyConstraint baseColumnNames="user_folio_details_id" baseTableName="user_folio_value"
                                 baseTableSchemaName="portfolio"
                                 constraintName="FK_USER_FOLIO_VALUE_ON_USER_FOLIO_DETAILS" referencedColumnNames="id"
                                 referencedTableName="user_folio_details" referencedTableSchemaName="portfolio"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="1716462000000-4" author="appUser">
        <addUniqueConstraint columnNames="date, user_folio_details_id" constraintName="uc_userfoliovalue_date_folio"
                             schemaName="portfolio" tableName="user_folio_value"/>
    </changeSet>

</databaseChangeLog>
